---
// src/components/Contact.astro
import { Icon } from 'astro-icon/components';
---

<section id="contacto" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-teal-600 rounded-[3rem] overflow-hidden shadow-2xl shadow-teal-200">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        
        <div class="p-8 md:p-16 text-white">
          <h2 class="text-3xl md:text-5xl font-bold mb-6">Agendar una cita es muy fácil</h2>
          <p class="text-teal-50 text-lg mb-10 leading-relaxed">
            Estamos listos para cuidar de tu mejor amigo. Escríbenos o visítanos directamente en nuestra clínica.
          </p>

          <div class="space-y-8">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-teal-500/50 flex items-center justify-center">
                <Icon name="lucide:phone" class="w-6 h-6" />
              </div>
              <div>
                <p class="text-sm text-teal-100">Llámanos</p>
                <p class="text-xl font-bold">+52 55 1234 5678</p>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-teal-500/50 flex items-center justify-center">
                <Icon name="lucide:mail" class="w-6 h-6" />
              </div>
              <div>
                <p class="text-sm text-teal-100">Correo electrónico</p>
                <p class="text-xl font-bold">hola@veterinaria.com</p>
              </div>
            </div>
            
            <a 
              href="https://wa.me/1234567890" 
              class="inline-flex items-center gap-3 bg-white text-teal-700 px-8 py-4 rounded-2xl font-bold hover:bg-teal-50 transition-colors shadow-lg"
            >
              <Icon name="lucide:message-circle" class="w-6 h-6" />
              Contactar por WhatsApp
            </a>
          </div>
        </div>

        <div class="bg-slate-50 p-8 md:p-16">
          <form class="space-y-6">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre del dueño</label>
              <input 
                type="text" 
                placeholder="Ej. Juan Pérez"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none transition-all"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre de la mascota</label>
                <input 
                  type="text" 
                  placeholder="Ej. Firulais"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Tipo de mascota</label>
                <select class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none bg-white text-slate-500">
                  <option>Perro</option>
                  <option>Gato</option>
                  <option>Otro</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-2">Mensaje o motivo de consulta</label>
              <textarea 
                rows="4" 
                placeholder="¿En qué podemos ayudarte?"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-teal-500 focus:border-teal-500 outline-none"
              ></textarea>
            </div>

            <button 
              type="submit" 
              class="w-full bg-teal-600 text-white py-4 rounded-xl font-bold hover:bg-teal-700 transition-all shadow-lg shadow-teal-100"
            >
              Enviar solicitud de cita
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>