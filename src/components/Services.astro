---
// src/components/Services.astro
import { Icon } from 'astro-icon/components';

const services = [
  {
    id: "consulta",
    title: "Consulta General",
    description: "Revisión completa para asegurar la salud preventiva de tu mejor amigo.",
    detailed: "Nuestras consultas incluyen un examen físico completo, revisión de signos vitales, peso, estado de la piel y pelaje. También ofrecemos asesoría nutricional y preventiva personalizada para cada etapa de vida de tu mascota.",
    icon: "lucide:stethoscope",
    image: "/images/service-consulta.webp" 
  },
  {
    id: "vacunas",
    title: "Vacunación",
    description: "Esquemas completos de vacunación y desparasitación interna y externa.",
    detailed: "Contamos con las mejores vacunas del mercado para proteger contra Rabia, Parvovirus, Moquillo y más. Incluimos recordatorios automáticos para que nunca olvides la próxima dosis de tu compañero.",
    icon: "lucide:syringe",
    image: "/images/service-vacunas.webp"
  },
  {
    id: "cirugia",
    title: "Cirugía",
    description: "Quirófano equipado para procedimientos esterilización y tejidos blandos.",
    detailed: "Realizamos esterilizaciones, limpiezas dentales y cirugías de tejidos blandos bajo protocolos estrictos de anestesia y monitoreo constante para garantizar la seguridad de tu mascota en todo momento.",
    icon: "lucide:scissors",
    image: "/images/service-cirugia.webp"
  },
  {
    id: "estetica",
    title: "Estética Canina",
    description: "Baño, corte de pelo y limpieza de oídos para que luzcan increíbles.",
    detailed: "Más que belleza, es salud. Incluye baño medicado o cosmético, corte de uñas, limpieza de glándulas anales y oídos, realizado por estilistas expertos en manejo amable.",
    icon: "lucide:bath",
    image: "/images/service-estetica.webp"
  }
];
---

<section id="servicios" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-5xl font-extrabold text-slate-950 mb-6 tracking-tight">
      Cuidado integral <span class="text-teal-600">para cada etapa</span>
    </h2>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-16">
      Atención médica de excelencia con un trato compasivo.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 hover:border-teal-200 hover:shadow-2xl transition-all group flex flex-col items-center">
          
          <div class="w-16 h-16 rounded-2xl bg-teal-100/60 text-teal-600 flex items-center justify-center mb-6 group-hover:bg-teal-600 group-hover:text-white transition-all">
            <Icon name={service.icon} class="w-8 h-8" />
          </div>
          
          <h3 class="text-xl font-bold text-slate-950 mb-3">{service.title}</h3>
          <p class="text-slate-600 text-sm mb-6 flex-grow">{service.description}</p>
          
          <button 
            data-open-modal={`modal-${service.id}`}
            class="text-sm font-semibold text-teal-600 flex items-center gap-1.5 hover:text-teal-700 transition-colors"
          >
            Saber más <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </button>

          <div 
            id={`modal-${service.id}`} 
            class="hidden fixed inset-0 z-[9999] flex items-center justify-center p-4"
          >
            <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm modal-overlay" data-close-modal={`modal-${service.id}`}></div>
            
            <div class="relative bg-white w-full max-w-lg rounded-[2rem] shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
              
              <div class="w-full h-48 md:h-56 overflow-hidden">
                <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
              </div>

              <button 
                data-close-modal={`modal-${service.id}`}
                class="absolute top-4 right-4 p-2 bg-white/90 rounded-full text-slate-600 shadow-md"
              >
                <Icon name="lucide:x" class="w-5 h-5" />
              </button>

              <div class="p-8 text-left">
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-10 h-10 rounded-lg bg-teal-50 text-teal-600 flex items-center justify-center">
                    <Icon name={service.icon} class="w-6 h-6" />
                  </div>
                  <h3 class="text-2xl font-bold text-slate-900">{service.title}</h3>
                </div>
                <p class="text-slate-600 mb-8 leading-relaxed">{service.detailed}</p>
                <a href="#contacto" class="block w-full py-4 bg-teal-600 text-white rounded-2xl font-bold text-center shadow-lg shadow-teal-100">
                  Agendar Cita
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const setupModals = () => {
    const openBtns = document.querySelectorAll('[data-open-modal]');
    const closeBtns = document.querySelectorAll('[data-close-modal]');

    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-open-modal');
        const modal = document.getElementById(id!);
        if (modal) {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    closeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-close-modal');
        const modal = document.getElementById(id!);
        if (modal) {
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }
      });
    });
  };

  document.addEventListener('DOMContentLoaded', setupModals);
  document.addEventListener('astro:page-load', setupModals);
</script>