---
// src/components/Hero.astro
---

<section id="inicio" class="relative bg-white pt-24 pb-16 lg:pt-32 lg:pb-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-center">
      
      <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left">
        <span class="inline-flex items-center rounded-full bg-teal-100 px-3 py-1 text-sm font-semibold text-teal-700 ring-1 ring-inset ring-teal-200 mb-4">
          Cuidado compasivo para tus compañeros
        </span>
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-950 sm:text-5xl md:text-6xl">
          El bienestar de tu mascota <span class="text-teal-600">es nuestra misión</span>.
        </h1>
        <p class="mt-3 text-base text-slate-600 sm:mt-5 sm:text-xl lg:text-lg xl:text-xl">
          Ofrecemos atención médica integral, vacunas, y servicios de emergencia las 24 horas con un equipo de profesionales apasionados por el cuidado animal.
        </p>
        
        <div class="mt-8 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0 flex flex-col sm:flex-row gap-4">
          <a 
            href="#contacto" 
            class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-white bg-teal-600 hover:bg-teal-700 md:py-4 md:text-lg transition shadow-xl shadow-teal-200"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Agendar Cita
          </a>
          <a 
            href="#servicios" 
            class="inline-flex items-center justify-center px-8 py-3 border border-slate-200 text-base font-medium rounded-full text-slate-800 bg-white hover:bg-slate-50 md:py-4 md:text-lg transition"
          >
            Nuestros Servicios
          </a>
        </div>
      </div>

      <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-8 scale-75 lg:scale-100 lg:-translate-x-0 lg:top-[-10%] lg:left-[-15%] opacity-30">
          <svg width="404" height="384" fill="none" viewBox="0 0 404 384">
            <defs>
              <pattern id="d3eb07ae-5182-43e6-857d-35c643af9034" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                <rect x="0" y="0" width="4" height="4" class="text-teal-300" fill="currentColor" />
              </pattern>
            </defs>
            <rect width="404" height="384" fill="url(#d3eb07ae-5182-43e6-857d-35c643af9034)" />
          </svg>
        </div>
        
        <div class="relative mx-auto w-full rounded-3xl shadow-2xl shadow-slate-200 overflow-hidden lg:max-w-md ring-1 ring-black ring-opacity-5">
          <img 
            class="w-full object-cover object-center aspect-[4/5]" 
            src="/hero-mascota.webp" 
            alt="Veterinaria sonriendo mientras atiende a un perro feliz en la consulta" 
          />
        </div>
      </div>

    </div>
  </div>
</section>