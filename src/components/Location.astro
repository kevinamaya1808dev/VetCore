---
// src/components/Location.astro
import { Icon } from 'astro-icon/components';
---

<section id="ubicacion" class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">¿Dónde encontrarnos?</h2>
        <p class="text-slate-600 mb-8 text-lg">
          Estamos ubicados en el corazón de la ciudad, listos para recibirte a ti y a tu mascota con instalaciones de primera.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center text-teal-600 flex-shrink-0">
              <Icon name="lucide:map-pin" class="w-6 h-6" />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">Dirección</h4>
              <p class="text-slate-600">Av. Principal #123, Colonia Mascotas, Ciudad México</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center text-teal-600 flex-shrink-0">
              <Icon name="lucide:clock" class="w-6 h-6" />
            </div>
            <div class="w-full">
              <h4 class="font-bold text-slate-900 mb-2">Horarios de Atención</h4>
              <div class="grid grid-cols-2 gap-2 text-slate-600 text-sm">
                <span>Lunes a Viernes:</span>
                <span class="font-medium text-slate-900">09:00 AM - 08:00 PM</span>
                <span>Sábados:</span>
                <span class="font-medium text-slate-900">10:00 AM - 04:00 PM</span>
                <span class="text-teal-600 font-semibold">Domingos:</span>
                <span class="font-semibold text-teal-600">Emergencias 24h</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="h-[400px] w-full rounded-3xl overflow-hidden shadow-2xl border-4 border-white">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.4801!2d-99.1678!3d19.4326!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDI1JzU3LjQiTiA5OcKwMTAnMDQuMSJX!5e0!3m2!1ses!2smx!4v1700000000000!5m2!1ses!2smx" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>
  </div>
</section>